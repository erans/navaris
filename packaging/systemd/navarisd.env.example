# Core daemon settings
# NAVARISD_BIN=/usr/local/bin/navarisd
# NAVARISD_LAUNCHER=/usr/local/lib/navaris/navarisd-launch.sh
NAVARIS_LISTEN=:8080
NAVARIS_DB_PATH=/var/lib/navaris/navaris.db
NAVARIS_LOG_LEVEL=info
# NAVARIS_AUTH_TOKEN=

# Incus backend
NAVARIS_INCUS_SOCKET=/var/lib/incus/unix.socket

# Firecracker backend
# Install firecracker/jailer with:
#   scripts/install-firecracker-runtime.sh --link-dir /usr/local/bin
#
# Firecracker is optional. Leave these unset to run Incus-only.
# NAVARIS_FIRECRACKER_BIN=/usr/local/lib/navaris/firecracker/bin/firecracker
# NAVARIS_JAILER_BIN=/usr/local/lib/navaris/firecracker/bin/jailer
# NAVARIS_KERNEL_PATH=/var/lib/navaris/firecracker/vmlinux
# NAVARIS_IMAGE_DIR=/var/lib/navaris/firecracker/images
# NAVARIS_CHROOT_BASE=/var/lib/navaris/firecracker/vm
# NAVARIS_SNAPSHOT_DIR=/var/lib/navaris/firecracker/snapshots
# NAVARIS_ENABLE_JAILER=true

# Copy-on-write storage backend (see docs/storage-backends.md)
# auto = probe each storage root; reflink on btrfs / XFS-reflink / bcachefs, copy otherwise.
# copy = always full byte copy (no FS prerequisites).
# reflink = explicit reflink, fails startup if the host FS does not support FICLONE.
# NAVARIS_STORAGE_MODE=auto

# Incus storage pool advisory: when true, refuse to start if the Incus pool
# driver (default pool, normally "default") is not CoW-capable (dir, lvm).
# NAVARIS_INCUS_STRICT_POOL_COW=false

# Web UI
# NAVARIS_UI_PASSWORD=
# NAVARIS_UI_SESSION_KEY=
# NAVARIS_UI_SESSION_TTL=24h

# Embedded MCP
# NAVARIS_MCP_ENABLED=false
# NAVARIS_MCP_READ_ONLY=false
# NAVARIS_MCP_PATH=/v1/mcp
# NAVARIS_MCP_MAX_TIMEOUT=10m
