# Minimal Firecracker microVM kernel config for x86_64.
# Merged on top of defconfig via scripts/kconfig/merge_config.sh.

# Disable ACPI and PCI — Firecracker uses virtio-mmio, not PCI.
# ACPI causes device conflicts with cmdline virtio_mmio.device= params.
CONFIG_ACPI=n
CONFIG_PCI=n

# Virtio MMIO cmdline device registration (Firecracker passes these).
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y

# Virtio devices
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y
CONFIG_VSOCKETS=y
CONFIG_VSOCKETS_DIAG=y

# IP autoconfiguration for kernel cmdline ip= parameter.
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y

# Random number generation (needed for modern userspace)
CONFIG_RANDOM_TRUST_CPU=y
