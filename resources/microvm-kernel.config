# Minimal Firecracker microVM kernel config for x86_64.
# Used with KCONFIG_ALLCONFIG + make allnoconfig to force these =y.

# Basic x86_64
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_HZ_250=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_IDLE=y
CONFIG_PRINTK=y
CONFIG_BUG=y

# KVM guest support
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y

# Virtio (MMIO transport — Firecracker uses MMIO, not PCI)
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VHOST=y
CONFIG_VHOST_VSOCK=y
CONFIG_VSOCKETS=y

# Block layer
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Filesystem support
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_MISC_FILESYSTEMS=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y

# Init / ELF loading
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_EXEC_FORMAT=y

# Misc required by userspace
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_INOTIFY_USER=y
CONFIG_SHMEM=y
CONFIG_AIO=y
CONFIG_IO_URING=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMBARRIER=y
CONFIG_KALLSYMS=y
CONFIG_MULTIUSER=y
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_POSIX_TIMERS=y

# Random number generation (needed for modern userspace)
CONFIG_RANDOM_TRUST_CPU=y
